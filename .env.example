# Nginx Reverse Proxy Gateway Environment Configuration Example
# Copy this file to .env and modify according to your needs

# ============================================
# Required Configuration
# ============================================

# Domain configuration - Your domain name
DOMAIN=your-domain.com

# Let's Encrypt configuration - Your email for certificate notifications
# IMPORTANT: Change this to your actual email address
LETSENCRYPT_EMAIL=admin@example.com

# ============================================
# Nginx Configuration
# ============================================

# Nginx configuration
NGINX_WORKER_PROCESSES=auto
NGINX_WORKER_CONNECTIONS=1024
CLIENT_MAX_BODY_SIZE=10m

# Logging configuration
ACCESS_LOG=/var/log/nginx/access.log
ERROR_LOG=/var/log/nginx/error.log

# ============================================
# Frontend Service Configuration (Optional)
# ============================================

# Frontend service name (Docker service name)
FRONTEND_SERVICE_NAME=skateboard-frontend
# Frontend service port
FRONTEND_PORT=5173
# Frontend access path (URL path)
FRONTEND_PATH=/gfs/

# ============================================
# Backend Service Configuration (Optional)
# ============================================

# Backend service name (Docker service name)
BACKEND_SERVICE_NAME=skateboard-backend
# Backend service port
BACKEND_PORT=3000
# Backend access path (URL path)
BACKEND_PATH=/gfs/api/
