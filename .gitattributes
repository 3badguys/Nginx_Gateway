# Set default behavior to LF line endings for all files
* text=auto eol=lf

# Shell scripts must use LF
*.sh text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.template text eol=lf
.env text eol=lf

# Markdown and documentation
*.md text eol=lf

# Docker files
Dockerfile text eol=lf
.dockerignore text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
